//REPETIÇÃO DO NOME
import java.util.Scanner;

class Main {
    public static void main(String[] args) {
         
        Scanner input = new Scanner(System.in);
        
        int n;
        
        System.out.print("Digite o nome que deseja: ");
        String nome = input.next(); 
        
        System.out.println("\n---Repeticao do nome---");

        for (n = 0; n < 5; n++) {
            System.out.println("Nome escolhido: " + nome);
        }
        
        input.close(); 
    } 
}





//LANÇAMENTO DE NOTAS
import java.util.Scanner;

class Main {
    public static void main(String[] args) {
         
        Scanner input = new Scanner(System.in);
        
        double n1, n2, n3, n4;
        
        // Usei println com \n para pular uma linha e ficar mais organizado
        System.out.println("--- BEM VINDO AO PORTAL DO ALUNO, DIGITE AQUI AS NOTAS ---\n");
        
        // 1º Passo: Mostra a mensagem na tela
        System.out.print("Digite a Nota 1: ");
        // 2º Passo: O programa para, espera o usuário digitar e guarda em n1
        n1 = input.nextDouble(); 
        
        // Agora você pode repetir o mesmo processo para as outras notas:
        System.out.print("Digite a Nota 2: ");
        n2 = input.nextDouble();
        
        System.out.print("Digite a Nota 3: ");
        n3 = input.nextDouble();
        
        System.out.print("Digite a Nota 4: ");
        n4 = input.nextDouble();
        
              double media = (n1+n2+n3+n4)/4;
              System.out.println("\nMédia final é: ", media);
        
        if(media<=3) {
            System.out.println("Aluno ficou retido");
        }
        
        input.close(); 
    }
}
